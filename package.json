{
  "name": "parishmart-monorepo",
  "version": "1.0.0",
  "description": "Parishmart monorepo — faith-based marketplace platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:onboarding": "turbo run dev --filter=parishmart-client",
    "dev:marketplace": "turbo run dev --filter=parishmart-marketplace",
    "dev:api": "turbo run dev --filter=parishmart-server",
    "start": "cd apps/api && npm start",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:seed": "cd apps/api && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cypress": "^15.3.0",
    "turbo": "^2.0.0",
    "vite": "^6.3.6"
  },
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.842.0",
    "@aws-sdk/s3-request-presigner": "^3.842.0",
    "handlebars": "^4.7.8",
    "nodemailer": "^7.0.5"
  }
}
